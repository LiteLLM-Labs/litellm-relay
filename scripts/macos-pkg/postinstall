#!/bin/bash
#
# LiteLLM Relay package postinstall.
#
# Runs as root at install time. Relay is a per-user proxy (login-keychain CA
# trust + a user LaunchAgent), so this installs it for the active console user
# using the prebuilt binary — no Rust/cargo on the endpoint.
set -euo pipefail

PAYLOAD="/usr/local/litellm-relay"
INSTALLER="$PAYLOAD/install.sh"
BINARY="$PAYLOAD/litellm-relay"
CONFIG="$PAYLOAD/config.yaml"

console_user="$(/usr/bin/stat -f%Su /dev/console 2>/dev/null || echo root)"

if [[ -z "$console_user" || "$console_user" == "root" || "$console_user" == "loginwindow" || "$console_user" == "_mbsetupuser" ]]; then
  echo "No active console user; skipping per-user Relay setup." >&2
  echo "Relay payload staged at $PAYLOAD; it will install on next user login run." >&2
  exit 0
fi

console_uid="$(/usr/bin/id -u "$console_user")"

args=(--background --skip-setup --prebuilt-binary "$BINARY")
if [[ -f "$CONFIG" ]]; then
  args+=(--config-file "$CONFIG")
fi

echo "Installing LiteLLM Relay for console user: $console_user (uid $console_uid)"

# Run inside the user's GUI session so launchctl bootstrap gui/<uid> works.
/bin/launchctl asuser "$console_uid" /usr/bin/sudo -H -u "$console_user" \
  /bin/bash "$INSTALLER" "${args[@]}"

echo "LiteLLM Relay install complete for $console_user."
exit 0
